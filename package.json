{
  "name": "Opticsify-desktop",
  "version": "1.0.0",
  "description": "Desktop application for Opticsify web platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron . --dev",
    "build": "NODE_ENV=production electron-builder",
    "build:mac:x64": "NODE_ENV=production electron-builder --mac --x64 \"--config.mac.artifactName=Opticsify-Desktop-\\${version}-mac.\\${ext}\"",
    "build:mac:arm64": "NODE_ENV=production electron-builder --mac --arm64 \"--config.mac.artifactName=Opticsify-Desktop-\\${version}-arm64-mac.\\${ext}\"",
    "build:mac": "npm run build:mac:x64 && npm run build:mac:arm64",
    "build:win": "NODE_ENV=production electron-builder --win",
    "build:win32": "NODE_ENV=production electron-builder --win --ia32",
    "build:win64": "NODE_ENV=production electron-builder --win --x64",
    "build:linux": "NODE_ENV=production electron-builder --linux",
    "build:all": "NODE_ENV=production electron-builder --mac --win --linux",
    "dist": "npm run build",
    "pack": "NODE_ENV=production electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rm -rf dist build node_modules/.cache"
  },
  "keywords": [
    "electron",
    "desktop",
    "Opticsify",
    "web-app"
  ],
  "author": {
    "name": "Opticsify Team",
    "email": "support@Opticsify.com"
  },
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.6.2",
    "sweetalert2": "^11.26.20"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^38.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.opticsify.desktop",
    "productName": "Opticsify Desktop",
    "afterSign": "scripts/notarize.js",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "update-ui.js",
      "app-update.yml",
      "assets/**/*",
      "opticsify.png",
      "!node_modules/.cache",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "compression": "maximum",
    "asarUnpack": [
      "app-update.yml"
    ],
    "removePackageScripts": true,
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/icon.png",
      "target": "dmg",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "publisherName": "Opticsify Team",
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Opticsify-Desktop-Setup-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "Opticsify Desktop ${version}",
      "icon": "assets/icon.png",
      "background": "assets/dmg-background.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
